<canvas id="fish-canvas" style="position:fixed;bottom:0;left:0;width:100%;height:100%;pointer-events:none;z-index:40;"></canvas>

<script is:inline>
(function () {
  const canvas = document.getElementById("fish-canvas");
  const ctx = canvas.getContext("2d");

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener("resize", resize);

  function drawFish(x, y, scale, angle) {
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(angle);
    ctx.scale(scale, scale);

    ctx.strokeStyle = "#293241";
    ctx.fillStyle = "#293241";
    ctx.lineWidth = 1.5;
    ctx.lineCap = "round";
    ctx.lineJoin = "round";

    // body
    ctx.beginPath();
    ctx.ellipse(0, 0, 18, 9, 0, 0, Math.PI * 2);
    ctx.fill();

    // tail
    ctx.beginPath();
    ctx.moveTo(-18, 0);
    ctx.lineTo(-28, -10);
    ctx.lineTo(-28, 10);
    ctx.closePath();
    ctx.fill();

    // eye
    ctx.fillStyle = "white";
    ctx.beginPath();
    ctx.arc(10, -2, 3, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = "#293241";
    ctx.beginPath();
    ctx.arc(11, -2, 1.5, 0, Math.PI * 2);
    ctx.fill();

    // fin
    ctx.fillStyle = "#3d5a80";
    ctx.beginPath();
    ctx.moveTo(0, -9);
    ctx.lineTo(6, -18);
    ctx.lineTo(12, -9);
    ctx.closePath();
    ctx.fill();

    ctx.restore();
  }

  const fish = [];

  function spawnFish() {
    const w = canvas.width;
    const h = canvas.height;
    const x = Math.random() * (w * 0.6) + w * 0.2;
    const scale = 0.8 + Math.random() * 1.0;
    const peakHeight = h * (0.35 + Math.random() * 0.35);
    const duration = 1200 + Math.random() * 600;

    fish.push({
      x,
      startY: h + 20,
      peakY: h - peakHeight,
      scale,
      duration,
      start: performance.now(),
    });
  }

  function easeInOut(t) {
    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
  }

  function loop(now) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let i = fish.length - 1; i >= 0; i--) {
      const f = fish[i];
      const elapsed = now - f.start;
      const t = Math.min(elapsed / f.duration, 1);

      // parabolic arc: t=0 bottom, t=0.5 peak, t=1 bottom
      const arc = 1 - Math.abs(t * 2 - 1);
      const y = f.startY - (f.startY - f.peakY) * easeInOut(arc);

      // angle: rising = tilted up, falling = tilted down
      const angle = t < 0.5 ? -0.6 : 0.6;

      // fade out near end
      const alpha = t > 0.85 ? 1 - (t - 0.85) / 0.15 : 1;
      ctx.globalAlpha = alpha;

      drawFish(f.x, y, f.scale, angle);
      ctx.globalAlpha = 1;

      if (t >= 1) fish.splice(i, 1);
    }

    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);

  function scheduleNext() {
    const delay = 3000 + Math.random() * 7000;
    setTimeout(() => {
      spawnFish();
      scheduleNext();
    }, delay);
  }

  scheduleNext();
})();
</script>
